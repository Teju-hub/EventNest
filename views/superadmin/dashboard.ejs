    <script type="text/javascript">
      $(document).ready(function () {
          // Array of places for the dropdown
          var places = [
              "Andhra Pradesh", "Arunachal Pradesh", "Assam", "Bihar", "Chhattisgarh", "Goa", "Gujarat",
              "Haryana", "Himachal Pradesh", "Jharkhand", "Karnataka", "Kerala", "Madhya Pradesh", "Maharashtra",
              "Manipur", "Meghalaya", "Mizoram", "Nagaland", "Odisha", "Punjab", "Rajasthan", "Sikkim", "Tamil Nadu",
              "Telangana", "Tripura", "Uttar Pradesh", "Uttarakhand", "West Bengal"
          ];

          $('.edit-event').on('click', function () {
              var index = $(this).data('index');
              var event = allEvents[index];
              // console.log(event.eventid); 
              // console.log(index);
              // Set edit event form content dynamically
              $('#editEventModalLabel').text('Edit Event');
              $('#editEventContent').html(`
                  <form method="post" id="editEventForm" enctype="multipart/form-data">
                      <!-- Use the existing event object to populate the form fields -->
                      <input type="hidden" id="editEventId" name="eventid" value="${event.eventid}">

                      <div class="form-group">
                          <input type="text" class="form-control" id="editEventName" name="eventname" placeholder="Eventname" value="${event.eventname}" required>
                      </div>
                      <div class="form-group">
                          <textarea class="form-control" id="editEventDescription" name="eventdescription" placeholder="Event Description" required>${event.eventdescription}</textarea>
                      </div>
                      <div class="form-group">
                          <select class="form-control" id="editEventPlace" name="eventplace" required>
                              <option value="" disabled>Select State</option>
                              ${places.map(place => `<option value="${place}" ${event.eventplace === place ? 'selected' : ''}>${place}</option>`).join('')}
                          </select>
                      </div>
                      <div class="form-group">
                          <input type="datetime-local" class="form-control" id="editEventDate" name="eventdate" required>
                      </div>
                      <div class="form-group">
                          <div class="input-group">
                              <div class="input-group-prepend">
                                  <span class="input-group-text">₹</span>
                              </div>
                              <input type="text" class="form-control" id="editEventPrice" name="eventprice" placeholder="Event Price" value="${event.eventprice}" required>
                          </div>
                      </div>
                      <div class="form-group">
                          <input type="text" class="form-control" id="editEventImage" name="eventimg" value="${event.eventimg}" readonly>
                          <div class="custom-file">
                              <input type="file" class="custom-file-input" id="editEventImageFile" name="eventimg" accept="image/*">
                              <label class="custom-file-label" for="editEventImageFile">Choose new image</label>
                          </div>
                          <img src="${event.eventimg}" alt="Current Event Image" style="max-width: 20%;">
                      </div>

                      <div class="text-center">
                          <button type="button" id="saveEditBtn" class="btn btn-primary">Save Changes</button>
                      </div>
                  </form>
              `);
              
              var eventDate = new Date(event.eventdate);
              var localDate = new Date(eventDate.getTime() - eventDate.getTimezoneOffset() * 60000);
              var formattedDate = localDate.toISOString().slice(0, 16); // Format: YYYY-MM-DDTHH:mm
              // console.log(localDate); // Local date and time
              // console.log(formattedDate); // Formatted date and time
              document.getElementById('editEventDate').value = formattedDate;
              // Show the edit event modal
              $('#editEventModal').modal('show');
          });
          
      });
    </script>

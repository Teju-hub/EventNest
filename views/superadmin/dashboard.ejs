    <script>
      document.addEventListener('DOMContentLoaded', function () {
        // Get references to content areas
        const adminDashboard = document.getElementById('adminDashboard');
        const adminListContent = document.getElementById('adminListContent');
        const createAdminContent = document.getElementById('createAdminContent');
        const userListContent = document.getElementById('userListContent');
        const eventListContent = document.getElementById('eventListContent');
        const mailComposer = document.getElementById('mailComposer');
        const createRoleContent = document.getElementById('createRoleContent');


        // Function to show/hide content based on selected item
        function showContent(contentToShow) {
          adminDashboard.style.display = 'none';
          adminListContent.style.display = 'none';
          createAdminContent.style.display = 'none';
          userListContent.style.display = 'none';
          eventListContent.style.display = 'none';
          mailComposer.style.display = 'none';
          createRoleContent.style.display = 'none';


          if (contentToShow) {
            contentToShow.style.display = 'block';
          }
        }

        // Attach click event listeners to sidebar items
        document.querySelector('.dashboard').addEventListener('click', function () {
          showContent(adminDashboard);
        });

        document.querySelector('.admin-list').addEventListener('click', function () {
          showContent(adminListContent);
        });

        document.querySelector('.create-admin').addEventListener('click', function () {
          showContent(createAdminContent);
        });

        document.querySelector('.user-list').addEventListener('click', function () {
          showContent(userListContent);
        });

        document.querySelector('.event-list').addEventListener('click', function () {
          showContent(eventListContent);
        });

        document.querySelector('.mail-compose').addEventListener('click', function () {
          showContent(mailComposer);
        });

        document.querySelector('.create-role').addEventListener('click', function () {
          showContent(createRoleContent);
        });


        // Initialize content based on the default or initial selection
        // For example, show admin list by default
        showContent(adminDashboard);
      });
    </script>
    <script>
      $(document).ready(function() {
        $('#submitBtn').on('click', function() {
          // Prevent the default form submission behavior
          event.preventDefault();

          // Check for required fields
          if (!$('#username').val() || !$('#email').val() || !$('#password').val() || !$('#role').val()) {
            $('#errorContainer').html('All fields are required. Please fill them out.').addClass('d-block');
             // Hide error message after 3 seconds
            setTimeout(function () {
              $('#errorContainer').removeClass('d-block').html('');
            }, 3000);

            return;
          }

          // Gather form data
          var formData = $('#adminRegistrationForm').serialize();
    
          // Send form data using AJAX
          $.ajax({
            type: 'POST',
            url: '/admin/register',
            data: formData,
            success: function(response) {
              // Check the response from the server
              if (response.success) {
                // Redirect or handle success
                window.location.href = '/dashboard';
              } else {
                // Display errors
                $('#errorContainer').html(response.error).addClass('d-block');
                // Hide error message after 3 seconds
                setTimeout(function () {
                  $('#errorContainer').removeClass('d-block').html('');
                }, 3000);
              }
            },
            error: function(error) {
              console.error('Error during registration:', error);
              $('#errorContainer').html('An error occurred during registration. Please try again later.').addClass('d-block');
              // Hide error message after 3 seconds
              setTimeout(function () {
                $('#errorContainer').removeClass('d-block').html('');
              }, 3000);
            }
          });
        });
      });

    </script>
    

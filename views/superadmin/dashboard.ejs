<!DOCTYPE html>
<html lang="en">
  <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>Super Admin Dashboard</title>
      <!-- Include Bootstrap CSS -->
      <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
      
      <!-- Font Awesome Icons -->
      <link rel="stylesheet" href="plugins/fontawesome-free/css/all.min.css">
      <!-- overlayScrollbars -->
      <link rel="stylesheet" href="plugins/overlayScrollbars/css/OverlayScrollbars.min.css">
      <!-- Theme style -->
      <link rel="stylesheet" href="dist/css/adminlte.min.css">
      <link rel="stylesheet" href="/css/dashboard.css">
     
  </head>

  <body class="hold-transition dark-mode sidebar-mini layout-fixed layout-navbar-fixed layout-footer-fixed">
    <div class="wrapper">
      <!-- Navbar -->
      <nav class="main-header navbar navbar-expand navbar-dark">
        <!-- Left navbar links -->
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
          </li>
          <li class="nav-item d-none d-sm-inline-block">
            <a href="#" class="nav-link">Home</a>
          </li>
        </ul>
    
        <!-- Right navbar links -->
        <ul class="navbar-nav ml-auto">
          <!-- Navbar Search -->
          <li class="nav-item">
            <a class="nav-link" data-widget="navbar-search" href="#" role="button">
              <i class="fas fa-search"></i>
            </a>
            <div class="navbar-search-block">
              <form class="form-inline">
                <div class="input-group input-group-sm">
                  <input class="form-control form-control-navbar" type="search" placeholder="Search" aria-label="Search">
                  <div class="input-group-append">
                    <button class="btn btn-navbar" type="submit">
                      <i class="fas fa-search"></i>
                    </button>
                    <button class="btn btn-navbar" type="button" data-widget="navbar-search">
                      <i class="fas fa-times"></i>
                    </button>
                  </div>
                </div>
              </form>
            </div>
          </li>
          <li class="nav-item">
            <a class="nav-link" data-widget="fullscreen" href="#" role="button">
              <i class="fas fa-expand-arrows-alt"></i>
            </a>
          </li>
        </ul>
      </nav>

      <!-- Main Sidebar Container -->
      <aside class="main-sidebar sidebar-dark-primary elevation-4">
        <div class="sidebar">
          <div class="user-panel mt-3 pb-3 mb-3 d-flex">
            <div class="image">
              <img src="dist/img/user2-160x160.jpg" class="img-circle elevation-2" alt="User Image">
            </div>
            <div class="info">
              <a href="#" class="d-block"><%= user.username %></a>
            </div>
          </div>
      
          <nav class="mt-2">
            <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
              <li class="nav-item menu-open">
                <a href="#" class="nav-link dashboard active">
                  <i class="nav-icon fas fa-tachometer-alt"></i>
                  <p>
                    Dashboard
                    <!-- <i class="right fas fa-angle-left"></i> -->
                  </p>
                </a>
              </li>
              <li class="nav-item">
                <a href="#" class="nav-link">
                  <i class="nav-icon fas fa-user-tie"></i>
                  <p>
                    Admin
                    <i class="right fas fa-angle-left"></i>
                  </p>
                </a>
                <ul class="nav nav-treeview">
                  <li class="nav-item">
                    <a href="#" class="nav-link admin-list">
                      <i class="far fa-circle nav-icon"></i>
                      <p>List of Admin</p>
                    </a>
                  </li>
                  <li class="nav-item">
                    <a href="#" class="nav-link create-admin">
                      <i class="far fa-circle nav-icon"></i>
                      <p>Create Admin</p>
                    </a>
                  </li>
                  <li class="nav-item">
                    <a href="#" class="nav-link create-role">
                      <i class="far fa-circle nav-icon"></i>
                      <p>Create Role</p>
                    </a>
                  </li>
                </ul>
              </li>
              <li class="nav-item">
                <a href="#" class="nav-link">
                  <i class="nav-icon fas fa-users"></i>
                  <p>
                    User
                    <i class="right fas fa-angle-left"></i>
                  </p>
                </a>
                <ul class="nav nav-treeview">
                  <li class="nav-item">
                    <a href="#" class="nav-link user-list">
                      <i class="far fa-circle nav-icon"></i>
                      <p>List of User</p>
                    </a>
                  </li>
                </ul>
              </li>
              <li class="nav-item">
                <a href="#" class="nav-link">
                  <i class="nav-icon fas fa-table"></i>
                  <p>
                    Events
                    <i class="fas fa-angle-left right"></i>
                  </p>
                </a>
                <ul class="nav nav-treeview">
                  <li class="nav-item">
                    <a href="#" class="nav-link event-list">
                      <i class="far fa-circle nav-icon"></i>
                      <p>All Events</p>
                    </a>
                  </li>
                </ul>
              </li>
              <li class="nav-item">
                <a href="#" class="nav-link">
                  <i class="nav-icon far fa-envelope"></i>
                  <p>
                    Mailbox
                    <i class="fas fa-angle-left right"></i>
                  </p>
                </a>
                <ul class="nav nav-treeview">
                  <li class="nav-item">
                    <a href="#" class="nav-link">
                      <i class="far fa-circle nav-icon"></i>
                      <p>Inbox</p>
                    </a>
                  </li>
                  <li class="nav-item">
                    <a href="#" class="nav-link mail-compose">
                      <i class="far fa-circle nav-icon"></i>
                      <p>Compose</p>
                    </a>
                  </li>
                </ul>
              </li>
              <li class="nav-item">
                <a href="/logout" class="nav-link">
                  <p class="text">Logout</p>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </aside>
    
      <!-- Content Wrapper. Contains page content -->
      <div class="content-wrapper">
        <!-- Content Header (Page header) -->
        <div class="content-header">
          <div class="container-fluid">
            <div class="row mb-2">
              <div class="col-sm-6">
                <h1 class="m-0">Dashboard</h1>
              </div><!-- /.col -->
              <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                  <li class="breadcrumb-item"><a href="#">Home</a></li>
                  <li class="breadcrumb-item active">Dashboard</li>
                </ol>
              </div><!-- /.col -->
            </div><!-- /.row -->
          </div><!-- /.container-fluid -->
        </div>
    
        <!-- Main content -->
        <section class="content">
          <div class="container-fluid">            
            <div class="row">
              <div class="col-md-12">
                <div id="adminDashboard">
                  <!-- Widgets -->
                  <div class="row">
                    <div class="col-md-3 col-sm-6 col-12">
                      <div class="info-box bg-success">
                        <span class="info-box-icon"><i class="fas fa-users"></i></span>
  
                        <div class="info-box-content">
                          <span class="info-box-text">Registered Users</span>
                          <span class="info-box-number">
                            <%= usersCount %>
                          </span>
  
                          <div class="progress">
                            <div class="progress-bar" style="width: <%= usersPercentage %>%"></div>
                          </div>
                          <span class="progress-description">
                            <%= usersPercentage %>%
                          </span>
                        </div>
                        <!-- /.info-box-content -->
                      </div>
                      <!-- /.info-box -->
                    </div>
                    <!-- /.col -->
                    <div class="col-md-3 col-sm-6 col-12">
                      <div class="info-box bg-info">
                        <span class="info-box-icon"><i class="far fa-calendar-alt"></i></span>
  
                        <div class="info-box-content">
                          <span class="info-box-text">Events</span>
                          <span class="info-box-number">
                            <%= eventsCount %>
                          </span>
  
                          <div class="progress">
                            <div class="progress-bar" style="width: <%= eventsPercentage %>%"></div>
                          </div>
                          <span class="progress-description">
                            <%= eventsPercentage %>%
                          </span>
                        </div>
                        <!-- /.info-box-content -->
                      </div>
                      <!-- /.info-box -->
                    </div>
                    <!-- /.col -->
                    <div class="col-md-3 col-sm-6 col-12">
                      <div class="info-box bg-warning">
                        <span class="info-box-icon"><i class="fa fa-calendar-alt"></i></span>
  
                        <div class="info-box-content">
                          <span class="info-box-text">Booked Events</span>
                          <span class="info-box-number">
                            <%= bookedEventsCount %>
                          </span>
  
                          <div class="progress">
                            <div class="progress-bar" style="width: <%= bookedEventsPercentage %>%"></div>
                          </div>
                          <span class="progress-description">
                            <%= bookedEventsPercentage %>%
                          </span>
                        </div>
                        <!-- /.info-box-content -->
                      </div>
                      <!-- /.info-box -->
                    </div>
                    <!-- /.col -->
                    <div class="col-md-3 col-sm-6 col-12">
                      <div class="info-box bg-danger">
                        <span class="info-box-icon"><i class="fa fa-exchange-alt"></i></span>
  
                        <div class="info-box-content">
                          <span class="info-box-text">Transactions</span>
                          <span class="info-box-number">
                            <%= transactionsCount %>
                          </span>
  
                          <div class="progress">
                            <div class="progress-bar" style="width: <%= transactionsPercentage %>%"></div>
                          </div>
                          <span class="progress-description">
                            <%= transactionsPercentage %>%
                          </span>
                        </div>
                        <!-- /.info-box-content -->
                      </div>
                      <!-- /.info-box -->
                    </div>
                    <!-- /.col -->
                  </div>
  
                  <!-- events charts -->
                  <div class="row">
                    <div class="col-sm-6">
                      <div class="card">
  
                        <div class="card-header">
                          <h5 class="card-title">Monthly Created Events Report</h5>
                          <div class="card-tools">
                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                              <i class="fas fa-minus"></i>
                            </button>
                            <button type="button" class="btn btn-tool" data-card-widget="remove">
                              <i class="fas fa-times"></i>
                            </button>
                          </div>
                        </div>
  
                        <div class="card-body">
                          <div class="row">
                            <div class="col-md-6 offset-sm-3">
                              <p class="text-center">
                                <strong>Events : Jul, 2023 - Dec, 2023</strong>
                              </p>
                              <div class="chart">
                                <!-- Sales Chart Canvas -->
                                <canvas id="eventsCreatedChart" style="height: 180px;"></canvas>
                              </div>
                            </div>
                          </div>
                        </div>
  
                      </div>
                    </div>
  
                    <div class="col-sm-6">
                      <div class="card">
                        <div class="card-header">
                          <h5 class="card-title">Monthly Booked Events Report</h5>
  
                          <div class="card-tools">
                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                              <i class="fas fa-minus"></i>
                            </button>
                            <button type="button" class="btn btn-tool" data-card-widget="remove">
                              <i class="fas fa-times"></i>
                            </button>
                          </div>
                        </div>
                        <!-- /.card-header -->
                        <div class="card-body">
                          <div class="row">
                            <div class="col-md-12">
                              <p class="text-center">
                                <strong>Booked Events : Jul, 2023 - Dec, 2023</strong>
                              </p>
  
                              <div class="chart">
                                <canvas id="eventsBookedChart" style="height: 180px;"></canvas>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  <!-- payment revenue -->
                  <div class="card">
                    <div class="card-header">
                      <h5 class="card-title">Monthly Payment Revenue</h5>
  
                      <div class="card-tools">
                        <button type="button" class="btn btn-tool" data-card-widget="collapse">
                          <i class="fas fa-minus"></i>
                        </button>
                        <button type="button" class="btn btn-tool" data-card-widget="remove">
                          <i class="fas fa-times"></i>
                        </button>
                      </div>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body">
                      <div class="row">
                        <div class="col-md-8">
                          <p class="text-center">
                            <strong>Sales: Jul, 2023 - Dec, 2023</strong>
                          </p>
  
                          <div class="chart">
                            <!-- <canvas id="salesChart" height="180" style="height: 180px;"></canvas> -->
                            <canvas id="paymentChart" style="height: 180px;"></canvas>
                          </div>
                          <!-- /.chart-responsive -->
                        </div>
                        <!-- /.col -->
                      </div>
                      <!-- /.row -->
                    </div>
                    <!-- ./card-body -->
                  </div><!-- /.card -->
                </div>

                <div class="card" id="adminListContent" style="display: none;">
                  <div class="card-header">
                    <h5 class="card-title">Admin List</h5>
                  </div>

                  <div class="card-body">
                    <div class="row">
                      <div class="col-md-12">
                        <div class="table-responsive">
                          <table class="table m-0">
                            <thead>
                            <tr>
                              <th>Sl No</th>
                              <th>Name</th>
                              <th>Mail Id</th>
                              <!-- <th>Authority</th> -->
                            </tr>
                            </thead>
                            <tbody>
                              <% admins.forEach((admin, index) => { %>
                                <tr>
                                  <td><%= index + 1 %></td>
                                  <td><%= admin.username %></td>
                                  <td><%= admin.email %></td>
                                  <!-- <td>X, Y, Z</td> // You may need to adjust this based on your data -->
                                </tr>
                              <% }); %>
                            </tbody>
                          </table>
                        </div>
                      </div>
                      <!-- /.col -->
                    </div>
                    <!-- /.row -->
                  </div>
                </div><!-- /.card -->

                <div class="card" id="createAdminContent" style="display: none;">
                  <div class="card-header">
                    <h5 class="card-title">Admin Registration</h5>
                  </div>

                  <div class="card-body">
                    <div class="row">
                      <div class="col-md-6 offset-md-3">
                        <div class="admin-signup-form">
                          <h1 class="text-center">Admin Sign Up</h1>

                          <p id="errorContainer" class="alert"></p>
                          
                          <form method="post" id="adminRegistrationForm" action="admin/register">
                              <div class="form-group">
                                  <input type="text" class="form-control" id="username" name="username" placeholder="Username"  required>
                              </div>
                              <div class="form-group">
                                  <input type="email" class="form-control" id="email" name="email" placeholder="Email" required>
                              </div>
                              <div class="form-group">
                                  <input type="password" class="form-control" id="password" name="password" placeholder="Password" autocomplete="new-password" required>
                              </div>
                              <div class="form-group">
                                  <select class="form-control" id="role" name="role" required>
                                      <option value="admin1">Admin1</option>
                                      <option value="admin2">Admin2</option>
                                  </select>
                              </div>
                              <div class="text-center">
                                  <button type="submit" id="submitBtn" class="btn btn-primary">Sign Up</button>
                              </div>
                          </form>
                      </div>
                      </div>
                      <!-- /.col -->
                    </div>
                    <!-- /.row -->
                  </div>
                </div><!-- /.card -->

                <div class="card" id="userListContent" style="display: none;">
                  <div class="card-header">
                    <h5 class="card-title">User List</h5>
                  </div>

                  <div class="card-body">
                    <div class="row">
                      <div class="col-md-12">
                        <div class="table-responsive">
                          <table class="table m-0">
                            <thead>
                              <tr>
                                <th>Sl No</th>
                                <th>Name</th>
                                <th>Mail Id</th>
                                <th>Events</th>
                              </tr>
                            </thead>
                            <tbody>
                              <% users.forEach((user, index) => { %>
                                <tr>
                                  <td><%= index + 1 %></td>
                                  <td><%= user.username %></td>
                                  <td><%= user.email %></td>
                                  <td>
                                    <% const userEvents = allEvents.filter(event => event.userid === user.id); %>
                                    <% if (userEvents.length > 0) { %>
                                      <% userEvents.forEach((event, index) => { %>
                                        <%= index + 1 === userEvents.length ? event.eventname : event.eventname + ', ' %>
                                      <% }); %>
                                    <% } else { %>
                                      No Events
                                    <% } %>
                                  </td>
                                </tr>
                              <% }); %>
                            </tbody>
                          </table>
                        </div>
                      </div>
                      <!-- /.col -->
                    </div>
                    <!-- /.row -->
                  </div>
                </div><!-- /.card -->

                <div class="card" id="eventListContent" style="display: none;">
                  <div class="card-header">
                    <h5 class="card-title">Event List</h5>
    
                    <div class="card-tools">
                      <button type="button" class="btn btn-tool" data-card-widget="collapse">
                        <i class="fas fa-minus"></i>
                      </button>
                      <button type="button" class="btn btn-tool" data-card-widget="remove">
                        <i class="fas fa-times"></i>
                      </button>
                    </div>
                  </div>

                  <div class="card-body">
                    <div class="row">
                      <div class="col-md-12">
                        <div class="table-responsive">
                          <table class="table event-table m-0">
                            <thead>
                              <tr>
                                <!-- <th>Sl No</th> -->
                                <th>Event Date</th>
                                <th>Image</th>
                                <th>Session</th>
                                <th>Venue</th>                                        
                                <th> </th>

                              </tr>
                            </thead>
                            <tbody>
                              <% allEvents.forEach((event, index) => { %>
                                <tr>
                                    <!-- <td><a href="#"><%= index + 1 %></a></td> -->
                                    <td class="eventdate">
                                        <span class="date">
                                        <%= new Date(event.eventdate).toLocaleString('en-IN', {day: 'numeric'}) %>
                                        </span>
                                        <p><%= new Date(event.eventdate).toLocaleString('en-IN', { month: 'long'}) %></p>
                                    </td>
                                    <td><img src="<%= event.eventimg %>" alt="Event Image"></td>
                                    <td>
                                        <div class="event-wrap">
                                            <h3><%= event.eventname %></h3>
                                            <div class="meta">
                                                <div class="organizers">
                                                  <i class="nav-icon fa fa-user"></i> <%= event.username %>
                                                </div>
                                                <div class="time">
                                                    <span><%= new Date(event.eventdate).toLocaleString('en-IN', { hour: 'numeric', minute: 'numeric', second: 'numeric' }) %></span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td><%= event.eventplace %></td>
                                    <td><a href="#" class="btn btn-primary event-details" data-toggle="modal" data-target="#eventDetailsModal" data-index="<%= index %>">Read More</a></td>
                                    <td>
                                      <a href="#" class="btn btn-warning edit-event" data-index="<%= index %>" data-toggle="modal" data-target="#editEventModal"><i class="fas fa-edit"></i></a>                    
                                      <a href="#" class="btn btn-danger delete-event" data-index="<%= index %>"><i class="fas fa-trash-alt"></i></a>
                                    </td>
                                    <!-- <td><a href="#" class="btn btn-primary event-details" data-index="<%= index %>">Read More</a></td> -->
                                    <!-- <td><%= event.eventname %></td> -->
                                    <!-- <td><%= event.eventdescription %></td> -->
                                    <!-- <td><%= new Date(event.eventdate).toLocaleString('en-IN', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: 'numeric', second: 'numeric' }) %></td> -->
                                    <!-- <td><%= new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR' }).format(event.eventprice) %></td> -->
                                    <!-- <td><img src="<%= event.eventimg %>" alt="Event Image" style="width: 50px; height: auto;"></td> -->
                                </tr>
                              <% }); %>
                            </tbody>
                          </table>
                        </div>
                      </div>
                      <!-- /.col -->
                    </div>
                    <!-- /.row -->
                  </div>
                </div><!-- /.card -->

                <div class="card" id="mailComposer" style="display: none;">
                  <div class="card-header">
                    <h5 class="card-title">Compose Mail </h5>
                  </div>
  
                  <div class="card-body">
                    <form id="composeMailForm">
                      <div class="form-group">
                        <label for="recipient">To:</label>
                        <!-- <input type="email" class="form-control" id="recipient" name="recipient" placeholder="Enter recipient email">  -->
                        <input type="text" class="form-control" id="recipient" placeholder="Enter recipient email(s)">
  
                      </div>
                      <div class="form-group">
                        <label for="subject">Subject:</label>
                        <input type="text" class="form-control" id="subject" name="subject"
                          placeholder="Enter email subject">
                      </div>
                      <div class="form-group">
                        <label for="message">Message:</label>
                        <textarea class="form-control" id="message" name="message" rows="5"
                          placeholder="Type your message here"></textarea>
                      </div>
                      <button type="submit" class="btn btn-primary" id="sendEmailBtn">Send Email</button>
                    </form>
                  </div>
                </div><!-- /.card -->

                <div class="card" id="createRoleContent" style="display: none;">
                  <div class="card-header">
                    <h5 class="card-title">Create Role</h5>
                  </div>
                  <!-- Add your form for creating roles here -->
                  <div class="card-body">
                    <div class="row">
                      <div class="col-md-4 offset-md-4" >
                        <form id="createRoleForm">
                          <div class="form-group">
                            <!-- <label for="roleName">Role Name:</label> -->
                            <input type="text" id="roleName" name="roleName" class="form-control" placeholder="Role Name" style="border-radius: 20px;" required>
                          </div>
                          
                          <div class="form-group">
                            <label>Access Levels:</label>
                            <div class="form-check">
                              <input type="checkbox" id="readAccess" name="readAccess" class="form-check-input">
                              <label class="form-check-label" for="readAccess">Read</label>
                            </div>
                            <div class="form-check">
                              <input type="checkbox" id="writeAccess" name="writeAccess" class="form-check-input">
                              <label class="form-check-label" for="writeAccess">Write</label>
                            </div>
                            <div class="form-check">
                              <input type="checkbox" id="viewAccess" name="viewAccess" class="form-check-input">
                              <label class="form-check-label" for="viewAccess">View</label>
                            </div>
                            <div class="form-check">
                              <input type="checkbox" id="deleteAccess" name="deleteAccess" class="form-check-input">
                              <label class="form-check-label" for="deleteAccess">Delete</label>
                            </div>
                          </div>
                          <div class="text-center">
                            <button  class="btn btn-primary" type="button" onclick="createRole()">Create Role</button>
                          </div>
                        </form>
                      </div>
                    </div>
                  </div>
                </div>

              </div> <!-- /.col -->
            </div><!-- /.row -->
          </div><!--/. container-fluid -->
        </section>
      </div>
      <!-- /.content-wrapper -->
        <!-- event details Modal -->
        <div class="modal fade" id="eventDetailsModal" tabindex="-1" role="dialog" aria-labelledby="eventDetailsModalLabel" aria-hidden="true">
          <div class="modal-dialog" role="document">
              <div class="modal-content">
                  <div class="modal-header">
                  <h5 class="modal-title" id="eventDetailsModalLabel">Event Details</h5>

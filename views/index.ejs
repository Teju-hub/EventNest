<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EventNest</title>
    <!-- Include Bootstrap CSS -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <!-- Font Awesome icons (free version)-->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css" integrity="sha384-…" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/index.css">

   
</head>
<body>
    <body id="page-top">
        <!-- Navigation-->
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
            <div class="container">
                <a class="navbar-brand" href="#page-top"><img src="../image/eventnest-logo1.png" alt="..." /></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
                    Menu
                    <i class="fas fa-bars ms-1"></i>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarResponsive">
                    <ul class="navbar-nav text-uppercase ms-auto py-4 py-lg-0">
                        <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
                        <li class="nav-item"><a class="nav-link" href="#portfolio">Portfolio</a></li>
                        <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
                        <li class="nav-item"><a class="nav-link" href="#team">Team</a></li>
                        <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
                    </ul>
                </div>
            </div>
        </nav>
       
        <!-- Masthead-->
        <header class="masthead">
           
            <div class="container">
                <div class="masthead-subheading">Welcome To EventNest</div>
                <div class="masthead-heading text-uppercase">It's Nice To Meet You</div>
                
                <% if (!isAuthenticated) { %>
                    <div class="user-auth">
                        <div class="user-register">
                            <!-- <a class="btn btn-danger" href="/admin/login"> Admin Login</a> -->
                            <a class="btn btn-danger btn-xl" href="/register">Register</a>
                        </div>
                        <div class="user-login">
                            <!-- <a class="btn btn-danger" href="/superadmin/login"> Super Admin Login</a> -->
                            <a class="btn btn-danger btn-xl" href="/login">Login</a>
                        </div>
                    </div>
                <% } else { %>
                    <div class="user-authenticated" >
                        <div class="user-loggedin">
                            <div class="user-img mr-2">
                                <img src="dist/img/user.jpg" class="img-circle" alt="User Image" style="height: 40px; width: 40px;"/>
                            </div>
                            <div class="info">
                                <h3><%= user.username %></h3>
                            </div>
                        </div>
                        <a class="btn btn-danger btn-xl mr-4" href="/dashboard">Dashboard</a>
                        <a class="btn btn-danger btn-xl" href="/user-logout">logout</a>
                    </div>
                <% } %>
            </div>
        </header>
        <!-- Services-->
        <section class="page-section" id="services">
            <div class="container">
                <div class="text-center">
                    <h2 class="section-heading text-uppercase">Services</h2>
                    <h3 class="section-subheading text-muted">With us, customization is guaranteed.</h3>
                </div>
                <div class="row text-center">
                    <div class="col-md-4">
                        <span class="service-img">
                            <img src="../image/wedding.jpg" alt="..." />
                        </span>
                        <h4 class="my-3">Weddings</h4>
                        <p class="text-muted">With every last detail taken care of, we're here to ensure the day you've always dreamed of will be the day you'll never forget.</p>
                    </div>
                    <div class="col-md-4">
                        <span class="service-img">
                            <img src="../image/social-gather.jpg" alt="..." />
                        </span>
                        <h4 class="my-3">Social Gatherings</h4>
                        <p class="text-muted">From a show stopping engagement celebration to an epic surprise birthday party, you dream it and we'll make it a reality.</p>
                    </div>
                    <div class="col-md-4">
                        <span class="service-img">
                            <img src="../image/corporate-event.jpg" alt="..." />
                        </span>
                        <h4 class="my-3">Corporate Events</h4>
                        <p class="text-muted">Wow your guests with a unique corporate experience that aligns with your company's mission and elevates your brand.</p>
                    </div>
                </div>
            </div>
        </section>
        <!-- Portfolio Grid-->
        <section class="page-section bg-light" id="portfolio">
            <div class="container">
                <div class="text-center">
                    <h2 class="section-heading text-uppercase">Portfolio</h2>
                    <h3 class="section-subheading text-muted">Book your events now.</h3>
                </div>
                <div class="row">
                    <% for (const event of events) { %>
                        <div class="col-lg-4 col-sm-6 mb-4">
                            <div class="portfolio-item">
                              <a class="portfolio-link" data-bs-toggle="modal" data-bs-target="#eventModal<%= event.eventid %>">
                                <div class="portfolio-hover">
                                  <div class="portfolio-hover-content"><i class="fas fa-plus fa-3x"></i></div>
                                </div>
                                <img class="img-fluid" src="<%= event.eventimg %>" alt="<%= event.eventname %>" style="width: 400px; height: 200px;"/>
                              </a>
                              <div class="portfolio-caption">
                                <div class="portfolio-caption-heading"><%= event.eventname %></div>
                                <div class="portfolio-caption-subheading text-muted"><%= event.eventplace %></div>
                              </div>
                            </div>
                        </div>

                        <!-- Event Modal -->
                        <div class="portfolio-modal modal fade" id="eventModal<%= event.eventid %>" tabindex="-1" role="dialog" aria-labelledby="eventModalLabel<%= event.eventid %>" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                  <div class="close-modal" data-bs-dismiss="modal"><i class="fas fa-times"></i></div>
                                  <div class="container">
                                    <div class="row justify-content-center">
                                        <div class="col-lg-8">
                                            <div class="modal-body">
                                                <!-- Project details -->
                                                <h2 class="text-uppercase"><%= event.eventname %></h2>
                                                <p class="item-intro text-muted" style="text-align: center;">By EventNest</p>
                                                <img class="img-fluid d-block mx-auto" src="<%= event.eventimg %>" alt="<%= event.eventname %>" style="height: 400px;width: 600px;" />
                                                <p><%= event.eventdescription %></p>
                                                <ul class="list-inline">
                                                    <li>
                                                    <strong>Location:</strong>
                                                    <%= event.eventplace %>
                                                    </li>
                                                    <li>
                                                    <strong>Price:</strong>
                                                    ₹<%= new Intl.NumberFormat('en-IN').format(event.eventprice) %>
                                                    </li>
                                                </ul>
                                                
                                                <button class="btn btn-primary btn-xl text-uppercase book-now" data-event-id="<%= event.eventid %>">
                                                    Book Now
                                                </button>
                                                
                                            </div>
                                        </div>
                                    </div>
                                  </div>
                                </div>
                            </div>
                        </div>
                        <% } %>
                    
                </div>
            </div>
        </section>
        <!-- About-->
        <section class="page-section" id="about">
            <div class="container">
                <div class="text-center">
                    <h2 class="section-heading text-uppercase">About</h2>
                    <h3 class="section-subheading text-muted">EVENT PLANNING & DESIGN</h3>
                </div>
                <ul class="timeline">
                    <li>
                        <div class="timeline-image"><img class="rounded-circle img-fluid" src="../image/event_planning.jpg" alt="..." /></div>
                        <div class="timeline-panel">
                            <div class="timeline-heading">
                                <h4>2018-2019</h4>
                                <h4 class="subheading">Our Humble Beginnings</h4>
                            </div>
                            <div class="timeline-body"><p class="text-muted">Founded in 2018, Infinity Hospitality was created out of a love for dynamic events and fine dining. Our goal is to provide unparalleled event services and outstanding customer service.</p></div>
                        </div>
                    </li>
                    <li class="timeline-inverted">
                        <div class="timeline-image"><img class="rounded-circle img-fluid" src="../image/corporate-party.png" alt="..." /></div>
                        <div class="timeline-panel">
                            <div class="timeline-heading">
                                <h4>2020</h4>
                                <h4 class="subheading">An Agency is Born</h4>
                            </div>
                            <div class="timeline-body"><p class="text-muted">With us, customization is guaranteed. You'll be paired with an Infinity Event Team who will collaborate with you to bring your vision to life. We will team up with some of the best vendors in Nashville and take care of all the details like meeting scheduling, delivery dates, payments, day-of setup, and more.</p></div>
                        </div>
                    </li>
                    <li>
                        <div class="timeline-image"><img class="rounded-circle img-fluid" src="../image/decoo.jpg" alt="..." /></div>
                        <div class="timeline-panel">
                            <div class="timeline-heading">
                                <h4>2020-2022</h4>
                                <h4 class="subheading">Transition to Full Service</h4>
                            </div>
                            <div class="timeline-body"><p class="text-muted">The Infinity experience is unlike any other. Our full-service event planning and design team will guide you every step of the way, ensuring a stress-free experience from start to finish.</p></div>
                        </div>
                    </li>
                    <li class="timeline-inverted">
                        <div class="timeline-image"><img class="rounded-circle img-fluid" src="../image/decoration.jpg" alt="..." /></div>
                        <div class="timeline-panel">
                            <div class="timeline-heading">
                                <h4>2023</h4>
                                <h4 class="subheading">Phase Two Expansion</h4>
                            </div>
                            <div class="timeline-body"><p class="text-muted">When it’s showtime, our staff will work tirelessly to guarantee your event is effortless and unforgettable.

                            </p></div>
                        </div>
                    </li>
                    <li class="timeline-inverted">
                        <div class="timeline-image">
                            <h4>
                                Be Part
                                <br />
                                Of Our
                                <br />
                                Story!
                            </h4>
                        </div>
                    </li>
                </ul>
            </div>
        </section>
        <footer></footer>
        <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>

        <script>
            window.addEventListener('DOMContentLoaded', event => {

            // Navbar shrink function
            var navbarShrink = function () {
                const navbarCollapsible = document.body.querySelector('#mainNav');
                if (!navbarCollapsible) {
                    return;
                }
                if (window.scrollY === 0) {
                    navbarCollapsible.classList.remove('navbar-shrink')
                } else {
                    navbarCollapsible.classList.add('navbar-shrink')
                }

            };

            // Shrink the navbar 
            navbarShrink();

            // Shrink the navbar when page is scrolled
            document.addEventListener('scroll', navbarShrink);

            //  Activate Bootstrap scrollspy on the main nav element
            const mainNav = document.body.querySelector('#mainNav');
            if (mainNav) {
                new bootstrap.ScrollSpy(document.body, {
                    target: '#mainNav',
                    rootMargin: '0px 0px -40%',
                });
            };

            // Collapse responsive navbar when toggler is visible
            const navbarToggler = document.body.querySelector('.navbar-toggler');
            const responsiveNavItems = [].slice.call(
                document.querySelectorAll('#navbarResponsive .nav-link')
            );
            responsiveNavItems.map(function (responsiveNavItem) {
                responsiveNavItem.addEventListener('click', () => {
                    if (window.getComputedStyle(navbarToggler).display !== 'none') {
                        navbarToggler.click();
                    }
                });
            });

            });

        </script> 

        <!-- payment Implement -->
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const bookNowButtons = document.querySelectorAll('.book-now');

                bookNowButtons.forEach(button => {
                    button.addEventListener('click', async function () {
                        // Check if the user is authenticated
                        const isAuthenticated = <%- isAuthenticated %>;
                        let userId, userName, userEmail;

                         // Check if the user variable is defined
                        <% if (typeof user !== 'undefined') { %>
                            userId = <%= user.id %>;
                            userName = '<%= user.username %>';
                            userEmail = '<%= user.email %>';
                        <% } %>

                        console.log('isauthenticated :-',isAuthenticated);
                        console.log('userId:',userId);
                        console.log('userName:',userName);
                        console.log('user email :',userEmail,)

                        if (!isAuthenticated) {
                            alert('Please log in to make a payment.');
                            return;
                        }
                        const eventId = button.getAttribute('data-event-id');
                        // const eventId = button.dataset.eventId;
                        // console.log(eventId);
                        // Call your backend to initiate the payment
                        const response = await fetch('/initiate-payment', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                            },
                            body: new URLSearchParams({
                                eventId: eventId,
                                userId: userId,
                                userName: userName,
                            }).toString(),
                        });

                        const data = await response.json();

                        // Initialize Razorpay
                        const options = {
                            key: 'rzp_test_T1Gry87HH3pn5L', // your Razorpay key
                            amount: data.amount,
                            currency: 'INR',
                            name: 'EventNest',
                            description: 'Event Booking Payment',
                            order_id: data.orderId,
                            handler: async function (response) {
                                console.log('Razorpay Handler Invoked');
                                // Handle the payment success
                                console.log('Razorpay Response:', response);

                                // Check the payment status
                                const paymentStatus = response.razorpay_payment_id ? 'success' : 'failed';
                                // console.log(paymentStatus);
                                // console.log(data.orderId);
                                
                                // Send payment status to your server
                                const updateStatusResponse = await fetch('/update-payment-status', {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json',
                                    },
                                    body: JSON.stringify({ 
                                        orderId: data.orderId, status: paymentStatus, 
                                        userId, userName, userEmail, eventId
                                    }),
                                });

                               // Check if the payment status was successfully updated on the server
                                if (updateStatusResponse.ok) {
                                    // Payment status updated successfully
                                    alert('Payment successful!');
                                } else {
                                    // Failed to update payment status on the server
                                    alert('Failed to update payment status on the server.');
                                }
                            },
                            prefill: {
                                name: 'Tejaswini',
                                email: 'tejaswini.techdoodles@gmail.com', //tejaswininayak1996@gmail.com
                                contact: '6371727268',
                            },
                            notes: {
                                address: 'EventNest Office',
                            },
                            theme: {
                                color: 'blue',
                            },
                        };

                        const rzp = new Razorpay(options);
                        rzp.on('payment.failed', async function(data){
                            console.log('Payment failed:', data.error.code, data.error.description);
                            
                            console.log('data:',data.error);
                            console.log('orderId:',data.error.metadata.order_id); 
                            console.log('paymentId:',data.error.metadata.payment_id);
                            // Send payment status to your server
                            const updateStatusResponse = await fetch('/update-payment-status', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                },
                                body: JSON.stringify({ orderId: data.error.metadata.order_id, status: 'failed' }),
                            });
                            // Check if the payment status was successfully updated on the server
                            if (updateStatusResponse.ok) {
                                // Payment status updated successfully
                                alert('Payment failed! Please try again.');
                            } else {
                                // Failed to update payment status on the server
                                alert('Failed to update payment status on the server.');
                            }
                            
                        });
                        rzp.open();
                       
                    });
                });
            });
        </script>
    </body>
</html>

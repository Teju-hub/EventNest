  <!-- save edit event -->
  <script type="text/javascript">
    $(document).ready(function () {
      $('#editEventContent').on('click', '#saveEditBtn', function () {

        // event.preventDefault();
        console.log('hello');
        // Extract the edited data from the form and send it to the server
        var formData = new FormData($('#editEventForm')[0]);
        console.log('Form Data:', formData);
        for (let pair of formData.entries()) {
          console.log(pair[0] + ': ' + pair[1]);
        }
        $.ajax({
          type: 'POST',
          url: '/dashboard/edit-event',
          data: formData,
          contentType: false,
          processData: false,
          success: function (response) {
            if (response.success) {
              // Reload the page or update the event in the table without refreshing
              window.location.reload(); // or update the event in the table using JavaScript
            } else {
              // Display errors
              alert(response.error);

              // Handle errors when updating the event
              if (response.redirect) {
                window.location.href = response.redirect;
              }
            }
          },
          error: function (jqXHR, textStatus, errorThrown) {
            console.error('Error during event editing:', textStatus, errorThrown);
            // Check if the server responded with a 403 status code (Forbidden)
            if (jqXHR.status === 403) {
              alert('You have no access to edit this event.');
            } else {
              // Handle other errors when updating the event
            }
          }
        });
      });
    });
  </script>

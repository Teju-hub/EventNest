  <!-- compose mail -->
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const composeMailForm = document.getElementById('composeMailForm');
      const sendEmailBtn = document.getElementById('sendEmailBtn');

      // Add an event listener to the form for handling submission
      composeMailForm.addEventListener('submit', function (event) {
        event.preventDefault(); // Prevent the default form submission behavior

        // Get form data
        
        const recipient = document.getElementById('recipient').value;
        if (!recipient) {
          alert('Recipient is required.');
          return;
        }
        // Split the string into an array of email addresses
        const recipientEmailsArray = recipient.split(',');
        const subject = document.getElementById('subject').value;
        const message = document.getElementById('message').value;
        console.log(recipientEmailsArray);
        

        // For example, you can use fetch API to send the email
        fetch('/dashboard/send-email', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          // body: JSON.stringify({ recipient, subject, message }),
          body: JSON.stringify({ recipientEmails: [recipientEmailsArray], subject, message }),

        })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              // Redirect to dashboard if the email was sent successfully
              window.location.href = data.redirect;
            } else {
              // Handle error case
              console.error('Error:', data.error);
            }
          })
          .catch(error => {
            // Handle errors, e.g., show an error message
            console.error(error);
          });
      });
    });
  </script>

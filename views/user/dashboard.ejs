                                </div>
                            <!-- /.row -->
                            </div>
                        </div><!-- /.card -->

                        <div class="card" id="createEvent" style="display: none;">
                        <div class="card-header">
                            <h5 class="card-title">Create New Event</h5>
                        </div>

                        <div class="card-body">
                            <div class="row">
                            <div class="col-md-6 offset-md-3">
                                <div class="admin-signup-form">
                                <h1 class="text-center">Create Event</h1>

                                <p id="errorContainer" class="alert"></p>
                                
                                <form method="post" id="eventCreateForm"  enctype="multipart/form-data">
                                    <div class="form-group">
                                        <input type="text" class="form-control" id="eventname" name="eventname" placeholder="Eventname" required>
                                    </div>
                                    <div class="form-group">
                                        <textarea class="form-control" id="eventdescription" name="eventdescription" placeholder="Event Description" required></textarea>
                                    </div>
                                    <div class="form-group">

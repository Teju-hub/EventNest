                                <i class="fas fa-minus"></i>
                                </button>
                                <button type="button" class="btn btn-tool" data-card-widget="remove">
                                <i class="fas fa-times"></i>
                                </button>
                            </div>
                            </div>
        
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-12">
                                    <div class="table-responsive">
                                        <table class="table event-table m-0">
                                            <thead>
                                                <tr>
                                                    <!-- <th>Sl No</th> -->
                                                    <th>Event Date</th>
                                                    <th>Image</th>
                                                    <th>Session</th>
                                                    <th>Venue</th>                                        
                                                    <th> </th>
                                                    <th> </th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% userEvents.forEach((event, index) => { %>
                                                    <tr>
                                                        <!-- <td><a href="#"><%= index + 1 %></a></td> -->
                                                        <td class="eventdate">
                                                            <span class="date">
                                                            <%= new Date(event.eventdate).toLocaleString('en-IN', {day: 'numeric'}) %>
                                                            </span>
                                                            <p><%= new Date(event.eventdate).toLocaleString('en-IN', { month: 'long'}) %></p>
                                                        </td>
                                                        <td><img src="<%= event.eventimg %>" alt="Event Image"></td>
                                                        <td>
                                                            <div class="event-wrap">
                                                                <h3><%= event.eventname %></h3>
                                                                <div class="meta">
                                                                    <div class="organizers">
                                                                        <i class="nav-icon fa fa-user"></i> <%= user.username %> 
                                                                    </div>
                                                                    <div class="time">
                                                                        <span><%= new Date(event.eventdate).toLocaleString('en-IN', { hour: 'numeric', minute: 'numeric', second: 'numeric' }) %></span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td><%= event.eventplace %></td>
                                                        <td><a href="#" class="btn btn-primary event-details" data-toggle="modal" data-target="#eventDetailsModal" data-index="<%= index %>">Read More</a></td>
                                                        <td>
                                                            <a href="#" class="btn btn-warning edit-event" data-index="<%= index %>" data-toggle="modal" data-target="#editEventModal"><i class="fas fa-edit"></i></a>                    
                                                            <a href="#" class="btn btn-danger delete-event" data-index="<%= index %>"><i class="fas fa-trash-alt"></i></a>
                                                        </td>

                                                        <!-- <td><a href="#" class="btn btn-primary event-details" data-index="<%= index %>">Read More</a></td> -->
                                                        <!-- <td><%= event.eventname %></td> -->
                                                        <!-- <td><%= event.eventdescription %></td> -->
                                                        <!-- <td><%= new Date(event.eventdate).toLocaleString('en-IN', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: 'numeric', second: 'numeric' }) %></td> -->
                                                        <!-- <td><%= new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR' }).format(event.eventprice) %></td> -->
                                                        <!-- <td><img src="<%= event.eventimg %>" alt="Event Image" style="width: 50px; height: auto;"></td> -->
                                                    </tr>
                                                <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                    </div>
